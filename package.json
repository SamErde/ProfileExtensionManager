{
  "name": "personas",
  "displayName": "Personas",
  "description": "Easily manage your dev personas: the different Git identities, VS Code profiles, and extensions that you need in different contexts.",
  "version": "0.8.6",
  "publisher": "SamErde",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "icon": "media/icon-256.png",
  "galleryBanner": {
    "color": "#16213E",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SamErde/Personas"
  },
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "personas.showMatrix",
        "title": "Show Extension Matrix",
        "category": "Personas",
        "icon": "$(extensions)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "personas",
          "title": "Personas",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "personas": [
        {
          "id": "personas.welcome",
          "name": "Profiles",
          "type": "webview",
          "icon": "media/activity-icon.svg",
          "contextualTitle": "Personas"
        }
      ]
    },
    "configuration": {
      "title": "Personas",
      "properties": {
        "personas.openMatrixOnActivityBarClick": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "When enabled, activating the Personas sidebar automatically opens the Extension Matrix — including on window restore if the sidebar was left active. Disable to require clicking the \"Open Extension Matrix\" button instead."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "vscode:prepublish": "npm run build",
    "watch": "node esbuild.mjs --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "npm run build && tsc -p tsconfig.integration.json && node out-test/test/integration/runTests.js",
    "package": "node -e \"require('fs').mkdirSync('releases',{recursive:true})\" && vsce package --out releases/"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
